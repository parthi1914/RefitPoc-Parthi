{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Information"
    }
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "JsonPlaceholderBaseUrl": "https://jsonplaceholder.typicode.com",
    "AuthToken": "your-bearer-token-here",
    "ApiKey": "your-api-key-here",
    "Timeout": 30,
    "RetryCount": 3,
    "CircuitBreakerFailureCount": 5,
    "CircuitBreakerDuration": 30
  }
}
